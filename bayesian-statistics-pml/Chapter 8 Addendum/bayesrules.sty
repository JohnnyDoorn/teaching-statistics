\usepackage{xcolor}
\definecolor{bayespurple}{RGB}{85,46,107}
\definecolor{bookgray}{RGB}{236,236,236}
\definecolor{commentblue}{rgb}{0.44, 0.62, 0.69}
\definecolor{functionblue}{rgb}{0.06, 0.15, 0.47}
\definecolor{numbergreen}{rgb}{0.36, 0.62, 0.45}
\definecolor{argolive}{rgb}{0.51, 0.56, 0.23}
\definecolor{codebrown}{rgb}{0.2, 0.2, 0.2}
